# API keys for auto-posting (copy to .env and fill in)

# Twitter/X — get from developer.x.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn — get from linkedin.com/developers
LINKEDIN_ACCESS_TOKEN=

# Buffer (optional, manages all platforms) — get from buffer.com/developers
BUFFER_ACCESS_TOKEN=
